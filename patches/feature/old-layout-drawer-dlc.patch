+        inu_cancelCurrentAnimation();
+        android.animation.AnimatorSet animatorSet = new android.animation.AnimatorSet();
+        animatorSet.playTogether(android.animation.ObjectAnimator.ofFloat(this, INU_DRAWER_POSITION, (float) inu_drawerLayout.getMeasuredWidth()));
