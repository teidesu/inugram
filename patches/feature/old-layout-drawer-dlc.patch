     public boolean onTouchEvent(MotionEvent ev) {
+        if (inu_drawerLayout != null && !parentActionBarLayout.checkTransitionAnimation()) {
+            if (inu_drawerOpened && ev != null && ev.getX() > inu_drawerPosition && !inu_startedTracking) {
+                if (ev.getAction() == MotionEvent.ACTION_UP) inu_closeDrawer(false);
+                return true;
+            }
+            if ((inu_allowOpenDrawerBySwipe || inu_drawerOpened) && inu_allowOpenDrawer
+                    && parentActionBarLayout.getFragmentStack().size() == 1) {
+                if (ev != null && (ev.getAction() == MotionEvent.ACTION_DOWN || ev.getAction() == MotionEvent.ACTION_MOVE)
+                        && !inu_startedTracking && !inu_maybeStartTracking) {
+                    inu_startedTrackingX = (int) ev.getX();
+                    inu_startedTrackingY = (int) ev.getY();
+                    inu_startedTrackingPointerId = ev.getPointerId(0);
+                    inu_maybeStartTracking = true;
+                    inu_cancelCurrentAnimation();
+                    if (inu_velocityTracker != null) inu_velocityTracker.clear();
+                } else if (ev != null && ev.getAction() == MotionEvent.ACTION_MOVE
+                        && ev.getPointerId(0) == inu_startedTrackingPointerId) {
+                    if (inu_velocityTracker == null) inu_velocityTracker = VelocityTracker.obtain();
+                    float dx = ev.getX() - inu_startedTrackingX;
+                    float dy = Math.abs(ev.getY() - inu_startedTrackingY);
+                    inu_velocityTracker.addMovement(ev);
+                    if (inu_maybeStartTracking && !inu_startedTracking
+                            && (dx > 0 && dx / 3f > dy && Math.abs(dx) >= AndroidUtilities.getPixelsInCM(0.2f, true)
+                                || inu_drawerOpened && dx < 0 && Math.abs(dx) >= dy && Math.abs(dx) >= AndroidUtilities.getPixelsInCM(0.4f, true))) {
+                        inu_maybeStartTracking = false;
+                        inu_startedTracking = true;
+                        inu_startedTrackingX = (int) ev.getX();
+                        inu_beginTrackingSent = false;
+                        requestDisallowInterceptTouchEvent(true);
+                    } else if (inu_startedTracking) {
+                        if (!inu_beginTrackingSent) { inu_beginTrackingSent = true; }
+                        inu_setDrawerPosition(inu_drawerPosition + dx);
+                        inu_startedTrackingX = (int) ev.getX();
+                    }
+                } else if (ev == null || ev.getPointerId(0) == inu_startedTrackingPointerId
+                        && (ev.getAction() == MotionEvent.ACTION_CANCEL
+                            || ev.getAction() == MotionEvent.ACTION_UP
+                            || ev.getAction() == MotionEvent.ACTION_POINTER_UP)) {
+                    if (inu_velocityTracker == null) inu_velocityTracker = VelocityTracker.obtain();
+                    inu_velocityTracker.computeCurrentVelocity(1000);
+                    if (inu_startedTracking || (inu_drawerPosition != 0 && inu_drawerPosition != inu_drawerLayout.getMeasuredWidth())) {
+                        float velX = inu_velocityTracker.getXVelocity();
+                        float velY = inu_velocityTracker.getYVelocity();
+                        boolean back = inu_drawerPosition < inu_drawerLayout.getMeasuredWidth() / 2f
+                                && (velX < 3500 || Math.abs(velX) < Math.abs(velY))
+                                || velX < 0 && Math.abs(velX) >= 3500;
+                        if (!back) inu_openDrawer(!inu_drawerOpened && Math.abs(velX) >= 3500);
+                        else inu_closeDrawer(inu_drawerOpened && Math.abs(velX) >= 3500);
+                    }
+                    inu_startedTracking = false;
+                    inu_maybeStartTracking = false;
+                    if (inu_velocityTracker != null) { inu_velocityTracker.recycle(); inu_velocityTracker = null; }
+                }
+            } else {
+                if (ev == null || ev.getPointerId(0) == inu_startedTrackingPointerId
+                        && (ev.getAction() == MotionEvent.ACTION_CANCEL
+                            || ev.getAction() == MotionEvent.ACTION_UP
+                            || ev.getAction() == MotionEvent.ACTION_POINTER_UP)) {
+                    inu_startedTracking = false;
+                    inu_maybeStartTracking = false;
+                    if (inu_velocityTracker != null) { inu_velocityTracker.recycle(); inu_velocityTracker = null; }
+                }
+            }
+            return inu_startedTracking;
+        }
         return false;
     }
 
