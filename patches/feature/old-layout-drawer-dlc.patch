+    private static final android.util.Property<DrawerLayoutContainer, Float> INU_DRAWER_POSITION =
+            new android.util.Property<DrawerLayoutContainer, Float>(Float.class, "inu_drawerPosition") {
+                @Override public Float get(DrawerLayoutContainer o) { return o.inu_drawerPosition; }
