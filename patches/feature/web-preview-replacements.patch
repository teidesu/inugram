@@ -14046,6 +14046,7 @@ public class ChatActivity extends BaseFragment implements
             } else {
                 req.message = textToCheck.toString();
             }
+            req.message = desu.inugram.helpers.WebPreviewHelper.applyReplacements(req.message);
             if (foundWebPage != null && req.message.equals(foundWebPage.displayedText)) {
                 return;
             }
