+    public void inu_setDrawerLayout(FrameLayout layout, View listView, FrameLayout.LayoutParams lp) {
+        inu_drawerLayout = layout;
+        inu_drawerListView = listView;
+        addView(inu_drawerLayout, lp);
+        inu_drawerLayout.setVisibility(INVISIBLE);
+        if (inu_shadowLeft == null) {
+            inu_shadowLeft = getResources().getDrawable(R.drawable.menu_shadow);
+        }
+    }
+
+    @Keep
+    public void inu_setDrawerPosition(float value) {
+        if (inu_drawerLayout == null) return;
+        inu_drawerPosition = Math.max(0, Math.min(value, inu_drawerLayout.getMeasuredWidth()));
+        inu_drawerLayout.setTranslationX(inu_drawerPosition);
+        if (inu_drawerPosition > 0 && inu_drawerListView != null && inu_drawerListView.getVisibility() != VISIBLE) {
+            inu_drawerListView.setVisibility(VISIBLE);
+        }
+        inu_drawerLayout.setVisibility(inu_drawerPosition > 0 ? VISIBLE : INVISIBLE);
+        if (!parentActionBarLayout.getFragmentStack().isEmpty()) {
+            BaseFragment f = parentActionBarLayout.getFragmentStack().get(0);
+            f.setProgressToDrawerOpened(inu_drawerPosition / inu_drawerLayout.getMeasuredWidth());
+        }
+        inu_scrimOpacity = inu_drawerPosition / (float) inu_drawerLayout.getMeasuredWidth();
+        invalidate();
+    }
+
+    @Keep
+    public float inu_getDrawerPosition() { return inu_drawerPosition; }
+
+    public void inu_setAllowOpenDrawer(boolean value, boolean animated) {
+        inu_allowOpenDrawer = value;
+        if (!inu_allowOpenDrawer && inu_drawerPosition != 0) {
+            if (!animated) { inu_setDrawerPosition(0); inu_onDrawerAnimationEnd(false); }
+            else inu_closeDrawer(true);
+        }
+    }
+
+    public void inu_setAllowOpenDrawerBySwipe(boolean value) { inu_allowOpenDrawerBySwipe = value; }
+
+    public boolean inu_isDrawerOpened() { return inu_drawerOpened; }
+
+    public void inu_openDrawer(boolean fast) {
+        if (!inu_allowOpenDrawer || inu_drawerLayout == null) return;
+        inu_cancelCurrentAnimation();
+        AnimatorSet animatorSet = new AnimatorSet();
+        animatorSet.playTogether(ObjectAnimator.ofFloat(this, "inu_drawerPosition", inu_drawerLayout.getMeasuredWidth()));
+        animatorSet.setInterpolator(new DecelerateInterpolator());
+        animatorSet.setDuration(fast ? Math.max((int)(200f / inu_drawerLayout.getMeasuredWidth() * (inu_drawerLayout.getMeasuredWidth() - inu_drawerPosition)), 50) : 250);
+        animatorSet.addListener(new AnimatorListenerAdapter() {
+            @Override public void onAnimationEnd(Animator a) { inu_onDrawerAnimationEnd(true); }
+        });
+        animatorSet.start();
+        inu_currentAnimation = animatorSet;
+    }
+
+    public void inu_closeDrawer(boolean fast) {
+        if (inu_drawerLayout == null) return;
+        inu_cancelCurrentAnimation();
+        AnimatorSet animatorSet = new AnimatorSet();
+        animatorSet.playTogether(ObjectAnimator.ofFloat(this, "inu_drawerPosition", 0));
+        animatorSet.setInterpolator(new DecelerateInterpolator());
+        animatorSet.setDuration(fast ? Math.max((int)(200f / inu_drawerLayout.getMeasuredWidth() * inu_drawerPosition), 50) : 250);
+        animatorSet.addListener(new AnimatorListenerAdapter() {
+            @Override public void onAnimationEnd(Animator a) { inu_onDrawerAnimationEnd(false); }
+        });
+        animatorSet.start();
+        inu_currentAnimation = animatorSet;
+    }
+
+    private void inu_cancelCurrentAnimation() {
+        if (inu_currentAnimation != null) { inu_currentAnimation.cancel(); inu_currentAnimation = null; }
+    }
+
+    private void inu_onDrawerAnimationEnd(boolean opened) {
+        inu_startedTracking = false;
+        inu_currentAnimation = null;
+        inu_drawerOpened = opened;
+        sendAccessibilityEvent(AccessibilityEvent.TYPE_WINDOW_STATE_CHANGED);
+    }
