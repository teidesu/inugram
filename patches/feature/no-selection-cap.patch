diff --git a/TMessagesProj/src/main/java/org/telegram/messenger/MessagesController.java b/TMessagesProj/src/main/java/org/telegram/messenger/MessagesController.java
index 0000000..0000000 100644
--- a/TMessagesProj/src/main/java/org/telegram/messenger/MessagesController.java
+++ b/TMessagesProj/src/main/java/org/telegram/messenger/MessagesController.java
@@ -9316,6 +9316,15 @@ public class MessagesController extends BaseController implements NotificationCe
     }
 
     public void deleteMessages(ArrayList<Integer> messages, ArrayList<Long> randoms, TLRPC.EncryptedChat encryptedChat, long dialogId, boolean forAll, int mode, boolean cacheOnly, long taskId, TLObject taskRequest, int topicId, boolean movedToScheduled, int movedToScheduledMessageId) {
+        // inu_ chunk to dodge server 100-id limit on TL_*_deleteMessages; secret-chat randoms only travel with first chunk
+        if (taskId == 0 && taskRequest == null && !cacheOnly && messages != null && messages.size() > 100) {
+            int total = messages.size();
+            for (int i = 100; i < total; i += 100) {
+                ArrayList<Integer> chunk = new ArrayList<>(messages.subList(i, Math.min(i + 100, total)));
+                deleteMessages(chunk, null, null, dialogId, forAll, mode, false, 0, null, topicId, false, 0);
+            }
+            messages = new ArrayList<>(messages.subList(0, 100));
+        }
         final boolean scheduled = mode == ChatActivity.MODE_SCHEDULED;
         final boolean quickReplies = mode == ChatActivity.MODE_QUICK_REPLIES;
         if ((messages == null || messages.isEmpty()) && taskId == 0) {
