     }
 
+    public void inu_toggleVideoMode() {
+        setRecordVideoButtonVisible(!isInVideoMode(), true);
+    }
+
+    public void inu_startRecordingLocked(boolean video) {
+        createRecordCircle();
+        setRecordVideoButtonVisible(video, false);
+        // pre-set locked state so updateRecordInterface skips the slide-to-cancel intro
+        sendButtonVisible = true;
+        snapAnimationProgress = 1f;
+        slideToCancelProgress = 1f;
+        controlsScale = 1f;
+        lastRecordState = RECORD_STATE_PREPARING;
+        recordAudioVideoRunnable.run();
+        if (!recordingAudioVideo) {
+            // recording didn't start (e.g. missing permissions), reset state
+            sendButtonVisible = false;
+            return;
+        }
+        // the container must be visible for send button touch handling
+        audioVideoButtonContainer.setVisibility(VISIBLE);
+    }
