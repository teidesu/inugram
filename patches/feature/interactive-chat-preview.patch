From: alina sireneva <alina@tei.su>
Date: Fri, 24 Apr 2026 13:35:21 +0300
Subject: prevent tapping the chat preview from expanding it to avoid accidentally opening it, and also make the bubbles interactive while we're at it

---
 .../org/telegram/ui/ActionBar/ActionBarLayout.java |  8 ++++++++
 .../main/java/org/telegram/ui/ChatActivity.java    |  4 ++--
 .../main/java/org/telegram/ui/DialogsActivity.java | 14 +++++++++++++-
 3 files changed, 23 insertions(+), 3 deletions(-)

diff --git a/TMessagesProj/src/main/java/org/telegram/ui/ActionBar/ActionBarLayout.java b/TMessagesProj/src/main/java/org/telegram/ui/ActionBar/ActionBarLayout.java
index 0000000..0000000 100644
--- a/TMessagesProj/src/main/java/org/telegram/ui/ActionBar/ActionBarLayout.java
+++ b/TMessagesProj/src/main/java/org/telegram/ui/ActionBar/ActionBarLayout.java
@@ -1968,6 +1968,14 @@ public class ActionBarLayout extends FrameLayout implements INavigationLayout, F
         if (fragment == null || checkTransitionAnimation() || delegate != null && check && !delegate.needPresentFragment(this, params) || !fragment.onFragmentCreate()) {
             return false;
         }
+        if (inPreviewMode && !preview && desu.inugram.InuConfig.INTERACTIVE_CHAT_PREVIEW.getValue()) {
+            final NavigationParams deferred = params;
+            finishPreviewFragment();
+            AndroidUtilities.runOnUIThread(() -> {
+                if (!inPreviewMode) presentFragment(deferred);
+            }, 250);
+            return false;
+        }
         final boolean isSupportEdgeToEdge = fragment.isSupportEdgeToEdge();
         final boolean drawNavigationBar = fragment.drawEdgeNavigationBar();
 
diff --git a/TMessagesProj/src/main/java/org/telegram/ui/ChatActivity.java b/TMessagesProj/src/main/java/org/telegram/ui/ChatActivity.java
index 0000000..0000000 100644
--- a/TMessagesProj/src/main/java/org/telegram/ui/ChatActivity.java
+++ b/TMessagesProj/src/main/java/org/telegram/ui/ChatActivity.java
@@ -40532,12 +40532,12 @@ public class ChatActivity extends BaseFragment implements
 
         @Override
         public boolean canPerformActions() {
-            return actionBar != null && !actionBar.isActionModeShowed() && !isReport() && !inPreviewMode;
+            return actionBar != null && !actionBar.isActionModeShowed() && !isReport() && (!inPreviewMode || InuConfig.INTERACTIVE_CHAT_PREVIEW.getValue());
         }
 
         @Override
         public boolean canPerformReply() {
-            return !isReport() && !inPreviewMode;
+            return !isReport() && (!inPreviewMode || InuConfig.INTERACTIVE_CHAT_PREVIEW.getValue());
         }
 
         @Override
diff --git a/TMessagesProj/src/main/java/org/telegram/ui/DialogsActivity.java b/TMessagesProj/src/main/java/org/telegram/ui/DialogsActivity.java
index 0000000..0000000 100644
--- a/TMessagesProj/src/main/java/org/telegram/ui/DialogsActivity.java
+++ b/TMessagesProj/src/main/java/org/telegram/ui/DialogsActivity.java
@@ -8696,6 +8696,18 @@ public class DialogsActivity extends BaseFragment implements NotificationCenter.
             });
         }
 
+        if (desu.inugram.InuConfig.INTERACTIVE_CHAT_PREVIEW.getValue()) {
+            ActionBarMenuSubItem openChatItem = new ActionBarMenuSubItem(getParentActivity(), true, false);
+            openChatItem.setTextAndIcon(LocaleController.getString(R.string.SavedOpenChatNoCaps), R.drawable.msg_discussion);
+            openChatItem.setMinimumWidth(160);
+            openChatItem.setOnClickListener(e -> {
+                if (previewActivity[0] != null && previewActivity[0].getParentLayout() != null) {
+                    previewActivity[0].getParentLayout().expandPreviewFragment();
+                }
+            });
+            previewMenu[0].addView(openChatItem);
+        }
+
         if (!isCommunityCell) {
             ActionBarMenuSubItem markAsUnreadItem = new ActionBarMenuSubItem(getParentActivity(), true, false);
             if (cell.getHasUnread()) {
@@ -8898,7 +8910,7 @@ public class DialogsActivity extends BaseFragment implements NotificationCenter.
             } else {
                 presentFragmentAsPreviewWithMenu(previewActivity[0] = chatActivity1, previewMenu[0]);
                 if (chatActivity1 != null) {
-                    chatActivity1.allowExpandPreviewByClick = true;
+                    chatActivity1.allowExpandPreviewByClick = !desu.inugram.InuConfig.INTERACTIVE_CHAT_PREVIEW.getValue();
                     try {
                         chatActivity1.getAvatarContainer().getAvatarImageView().performAccessibilityAction(AccessibilityNodeInfo.ACTION_ACCESSIBILITY_FOCUS, null);
                     } catch (Exception ignore) {
