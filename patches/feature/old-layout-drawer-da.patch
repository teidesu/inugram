diff --git a/TMessagesProj/src/main/java/org/telegram/ui/DialogsActivity.java b/TMessagesProj/src/main/java/org/telegram/ui/DialogsActivity.java
index 0000000..0000000 100644
--- a/TMessagesProj/src/main/java/org/telegram/ui/DialogsActivity.java
+++ b/TMessagesProj/src/main/java/org/telegram/ui/DialogsActivity.java
@@ -545,6 +545,7 @@
     private boolean updatePullAfterScroll;
 
     private BackDrawable backDrawable;
+    private org.telegram.ui.ActionBar.MenuDrawable inu_menuDrawable;
 
     private final Paint actionBarDefaultPaint = new Paint();
 
@@ -3451,6 +3452,9 @@
         } else {
             if (searchString != null || folderId != 0) {
                 actionBar.setBackButtonDrawable(backDrawable = new BackDrawable(false));
+            } else if (!hasMainTabs && desu.inugram.InuConfig.OLD_LAYOUT.getValue()) {
+                actionBar.setBackButtonDrawable(inu_menuDrawable = new org.telegram.ui.ActionBar.MenuDrawable());
+                inu_menuDrawable.setRoundCap();
             }
             if (folderId != 0) {
                 actionBar.setTitle(getString(R.string.ArchivedChats));
@@ -3822,6 +3826,15 @@
                     return;
                 }
                 if (id == -1) {
+                    if (!hasMainTabs && desu.inugram.InuConfig.OLD_LAYOUT.getValue()
+                            && folderId == 0 && searchString == null
+                            && parentLayout != null
+                            && parentLayout.getDrawerLayoutContainer() != null) {
+                        org.telegram.ui.ActionBar.DrawerLayoutContainer dlc = parentLayout.getDrawerLayoutContainer();
+                        if (dlc.inu_isDrawerOpened()) dlc.inu_closeDrawer(false);
+                        else dlc.inu_openDrawer(false);
+                        return;
+                    }
                     if (rightSlidingDialogContainer != null && rightSlidingDialogContainer.hasFragment()) {
                         if (actionBar.isActionModeShowed()) {
                             if (searchViewPager != null && searchViewPager.getVisibility() == View.VISIBLE && searchViewPager.actionModeShowing()) {
