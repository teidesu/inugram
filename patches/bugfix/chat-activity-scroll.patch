diff --git a/TMessagesProj/src/main/java/org/telegram/ui/Components/chat/ChatListViewPaddingsAnimator.java b/TMessagesProj/src/main/java/org/telegram/ui/Components/chat/ChatListViewPaddingsAnimator.java
