+    private static class InuFadingSelector {
+        final Drawable drawable;
+        final int position;
+        final long itemId;
+
+        InuFadingSelector(Drawable drawable, int position, long itemId) {
+            this.drawable = drawable;
+            this.position = position;
+            this.itemId = itemId;
+        }
+    }
+
+    private final java.util.ArrayList<InuFadingSelector> inu_fadingSelectors = new java.util.ArrayList<>();
+    private long inu_selectorItemId = NO_ID;
+
+    private long inu_getItemIdAt(int position) {
+        Adapter adapter = getAdapter();
+        if (adapter == null || position < 0 || position >= adapter.getItemCount()) {
+            return NO_ID;
+        }
+        return adapter.getItemId(position);
+    }
+
+    private void inu_retireSelector() {
+        final Drawable prev = selectorDrawable;
+        if (prev == null || selectorRect.isEmpty()) {
+            return;
+        }
+        prev.setState(StateSet.NOTHING);
+        final InuFadingSelector fading = new InuFadingSelector(prev, selectorPosition, inu_selectorItemId);
+        inu_fadingSelectors.add(fading);
+        setSelectorDrawableColor(getThemedColor(hasSections() ? Theme.key_settings_listSelector : Theme.key_listSelector));
+        prev.setCallback(this);
+        AndroidUtilities.runOnUIThread(() -> {
+            inu_fadingSelectors.remove(fading);
+            prev.setCallback(null);
+            invalidate();
+        }, 1000);
+    }
+
+    private void inu_clearSelector() {
+        inu_retireSelector();
+        selectorRect.setEmpty();
+    }
