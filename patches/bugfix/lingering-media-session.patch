diff --git a/TMessagesProj/src/main/java/org/telegram/messenger/TelegramMediaSession.java b/TMessagesProj/src/main/java/org/telegram/messenger/TelegramMediaSession.java
index 0000000..0000000 100644
--- a/TMessagesProj/src/main/java/org/telegram/messenger/TelegramMediaSession.java
+++ b/TMessagesProj/src/main/java/org/telegram/messenger/TelegramMediaSession.java
@@ -89,6 +89,8 @@ public class TelegramMediaSession {
     private Paint roundPaint;
     private RectF bitmapRect;
 
+    private final NotificationCenter.NotificationCenterDelegate inu_accountObserver;
+
     private TelegramMediaSession(Context appContext) {
         this.appContext = appContext;
         this.currentAccount = UserConfig.selectedAccount;
@@ -120,12 +122,12 @@ public class TelegramMediaSession {
         updateRepeatMode();
         updateShuffleMode();
 
-        NotificationCenter.getGlobalInstance().addObserver(
-                (id, account, args) -> {
-                    if (id == NotificationCenter.activeAccountChanged) {
-                        AndroidUtilities.runOnUIThread(this::onAccountSwitched);
-                    }
-                }, NotificationCenter.activeAccountChanged);
+        inu_accountObserver = (id, account, args) -> {
+            if (id == NotificationCenter.activeAccountChanged) {
+                AndroidUtilities.runOnUIThread(this::onAccountSwitched);
+            }
+        };
+        NotificationCenter.getGlobalInstance().addObserver(inu_accountObserver, NotificationCenter.activeAccountChanged);
     }
 
     private void onAccountSwitched() {
@@ -187,6 +189,42 @@ public class TelegramMediaSession {
         }
     }
 
+    public void inu_deactivate() {
+        if (session == null) {
+            return;
+        }
+        try {
+            PlaybackStateCompat.Builder pb = new PlaybackStateCompat.Builder()
+                    .setState(PlaybackStateCompat.STATE_STOPPED, 0, 1f)
+                    .setActions(getAvailableActions());
+            session.setPlaybackState(pb.build());
+            session.setActive(false);
+        } catch (Throwable ignored) {
+        }
+    }
+
+    public void inu_releaseIfIdle() {
+        if (MusicBrowserService.inu_running || org.telegram.messenger.car.TelegramCarAppService.inu_running) {
+            inu_deactivate();
+            return;
+        }
+        synchronized (TelegramMediaSession.class) {
+            if (instance != this) {
+                return;
+            }
+            instance = null;
+        }
+        try {
+            NotificationCenter.getGlobalInstance().removeObserver(inu_accountObserver, NotificationCenter.activeAccountChanged);
+        } catch (Throwable ignored) {
+        }
+        try {
+            session.setActive(false);
+            session.release();
+        } catch (Throwable ignored) {
+        }
+    }
+
     public Bundle buildRootHints() {
         Bundle rootExtras = new Bundle();
         rootExtras.putBoolean(CONTENT_STYLE_SUPPORTED, true);
