index 6c37252d4..a340a8e72 100644
--- a/TMessagesProj/src/main/java/org/telegram/messenger/LiteMode.java
+++ b/TMessagesProj/src/main/java/org/telegram/messenger/LiteMode.java
@@ -53,35 +53,23 @@ public class LiteMode {
         FLAG_ANIMATED_EMOJI_CHAT_PREMIUM |
         FLAG_ANIMATED_EMOJI_KEYBOARD_PREMIUM |
         FLAG_ANIMATED_EMOJI_REACTIONS_PREMIUM |
-        FLAG_AUTOPLAY_GIFS |
-        FLAG_CHAT_THANOS |
-        FLAG_PARTICLES
+        FLAG_AUTOPLAY_GIFS
     ); // 198684
     public static int PRESET_MEDIUM = (
-        FLAGS_ANIMATED_STICKERS |
+        FLAG_ANIMATED_STICKERS_CHAT |
         FLAG_ANIMATED_EMOJI_KEYBOARD_PREMIUM |
         FLAG_ANIMATED_EMOJI_REACTIONS_PREMIUM |
         FLAG_ANIMATED_EMOJI_CHAT |
         FLAG_CHAT_FORUM_TWOCOLUMN |
-        FLAG_CALLS_ANIMATIONS |
         FLAG_AUTOPLAY_VIDEOS |
-        FLAG_AUTOPLAY_GIFS |
-        FLAG_CHAT_THANOS |
-        FLAG_PARTICLES
+        FLAG_AUTOPLAY_GIFS
     ); // 204383
     public static int PRESET_HIGH = (
-        FLAGS_ANIMATED_STICKERS |
-        FLAGS_ANIMATED_EMOJI |
-        FLAG_CHAT_BACKGROUND |
+        FLAG_ANIMATED_STICKERS_CHAT |
         FLAG_CHAT_FORUM_TWOCOLUMN |
-        FLAG_CHAT_SPOILER |
-        FLAG_CHAT_BLUR |
         FLAG_CHAT_SCALE |
-        FLAG_CHAT_THANOS |
-        FLAG_CALLS_ANIMATIONS |
         FLAG_AUTOPLAY_VIDEOS |
-        FLAG_AUTOPLAY_GIFS |
-        FLAG_PARTICLES
+        FLAG_AUTOPLAY_GIFS
