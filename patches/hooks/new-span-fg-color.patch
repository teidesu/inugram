From: Damir Modyarov <damir@otomir23.me>
Date: Thu, 30 Apr 2026 03:43:13 +0300
Subject: add ability to change foreground color for FilterCreateActivity.NewSpan

---
 .../main/java/org/telegram/ui/FilterCreateActivity.java  | 9 ++++++++-
 1 file changed, 8 insertions(+), 1 deletion(-)

diff --git a/TMessagesProj/src/main/java/org/telegram/ui/FilterCreateActivity.java b/TMessagesProj/src/main/java/org/telegram/ui/FilterCreateActivity.java
index 0000000..0000000 100644
--- a/TMessagesProj/src/main/java/org/telegram/ui/FilterCreateActivity.java
+++ b/TMessagesProj/src/main/java/org/telegram/ui/FilterCreateActivity.java
@@ -2254,6 +2254,11 @@ public class FilterCreateActivity extends BaseFragment {
             this.color = color;
         }
 
+        private int fgColor = -1;
+        public void setFgColor(int fgColor) {
+            this.fgColor = fgColor;
+        }
+
         private CharSequence text = "NEW";
         public void setText(CharSequence text) {
             this.text = text;
@@ -2290,7 +2295,9 @@ public class FilterCreateActivity extends BaseFragment {
                 color = paint.getColor();
             }
             bgPaint.setColor(color);
-            if (outline) {
+            if (fgColor != -1) {
+                textPaint.setColor(fgColor);
+            } else if (outline) {
                 textPaint.setColor(color);
             } else {
                 textPaint.setColor(AndroidUtilities.computePerceivedBrightness(color) > .721f ? Color.BLACK : Color.WHITE);
