From fe63150388f7eca128e3eb8c66a282fa7da3b67b Mon Sep 17 00:00:00 2001
From: alina sireneva <alina@tei.su>
Date: Thu, 9 Apr 2026 16:14:57 +0300
Subject: [PATCH] hide ai features

---
 TMessagesProj/src/main/java/org/telegram/ui/ArticleViewer.java  | 1 +
 .../src/main/java/org/telegram/ui/Cells/ChatMessageCell.java    | 2 +-
 .../java/org/telegram/ui/Components/ChatActivityEnterView.java  | 2 +-
 3 files changed, 3 insertions(+), 2 deletions(-)

diff --git a/TMessagesProj/src/main/java/org/telegram/ui/ArticleViewer.java b/TMessagesProj/src/main/java/org/telegram/ui/ArticleViewer.java
index 1435b2e26..e350c0458 100644
--- a/TMessagesProj/src/main/java/org/telegram/ui/ArticleViewer.java
+++ b/TMessagesProj/src/main/java/org/telegram/ui/ArticleViewer.java
@@ -1779,6 +1779,7 @@ public class ArticleViewer implements NotificationCenter.NotificationCenterDeleg
             int count = webPage.cached_page.blocks.size();
             for (int a = 0; a < count; a++) {
                 TLRPC.PageBlock block = webPage.cached_page.blocks.get(a);
+                if (desu.inugram.helpers.InstantViewHelper.shouldHideBlock(block)) continue;
                 if (a == 0) {
                     block.first = true;
                     if (block instanceof TLRPC.TL_pageBlockCover) {
diff --git a/TMessagesProj/src/main/java/org/telegram/ui/Cells/ChatMessageCell.java b/TMessagesProj/src/main/java/org/telegram/ui/Cells/ChatMessageCell.java
index fa4031b3f..3f9f56a63 100644
--- a/TMessagesProj/src/main/java/org/telegram/ui/Cells/ChatMessageCell.java
+++ b/TMessagesProj/src/main/java/org/telegram/ui/Cells/ChatMessageCell.java
@@ -6805,7 +6805,7 @@ public class ChatMessageCell extends BaseCell implements SeekBar.SeekBarDelegate
                     drawSideButton = 2;
                 }
             }
-            drawSummarizeButton = TranslateController.isSummarizable(messageObject);
+            drawSummarizeButton = !desu.inugram.InuConfig.HIDE_MESSAGE_SUMMARY.getValue() && TranslateController.isSummarizable(messageObject);
             hasReplyQuote = false;
             isReplyQuote = false;
             isReplyTaskOrPollOption = false;
diff --git a/TMessagesProj/src/main/java/org/telegram/ui/Components/ChatActivityEnterView.java b/TMessagesProj/src/main/java/org/telegram/ui/Components/ChatActivityEnterView.java
index b36ca2339..c9a451d63 100644
--- a/TMessagesProj/src/main/java/org/telegram/ui/Components/ChatActivityEnterView.java
+++ b/TMessagesProj/src/main/java/org/telegram/ui/Components/ChatActivityEnterView.java
@@ -5846,7 +5846,7 @@ public class ChatActivityEnterView extends FrameLayout implements
 
     private boolean shownAiButton;
     private void showAiButton(boolean show_) {
-        final boolean show = show_ && parentFragment != null && !parentFragment.isSecretChat();
+        final boolean show = show_ && parentFragment != null && !parentFragment.isSecretChat() && !desu.inugram.InuConfig.HIDE_AI_EDITOR.getValue();
 
         if (shownAiButton == show) return;
         shownAiButton = show;
-- 
2.52.0

