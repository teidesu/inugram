Subject: [PATCH] hide server-pushed suggestions throughout the app

---
 .../src/main/java/org/telegram/messenger/BirthdayController.java | 1 +
 .../src/main/java/org/telegram/messenger/MessagesController.java | 1 +
 2 files changed, 2 insertions(+)

diff --git a/TMessagesProj/src/main/java/org/telegram/messenger/BirthdayController.java b/TMessagesProj/src/main/java/org/telegram/messenger/BirthdayController.java
index 4441e841c..b66d04409 100644
--- a/TMessagesProj/src/main/java/org/telegram/messenger/BirthdayController.java
+++ b/TMessagesProj/src/main/java/org/telegram/messenger/BirthdayController.java
@@ -131,6 +131,7 @@ public class BirthdayController {
     }
 
     public boolean contains() {
+        if (desu.inugram.InuConfig.HIDE_SUGGESTION_BIRTHDAY_CONTACTS.getValue()) return false;
         final BirthdayState state = getState();
         return state != null && !state.isTodayEmpty();
     }
diff --git a/TMessagesProj/src/main/java/org/telegram/messenger/MessagesController.java b/TMessagesProj/src/main/java/org/telegram/messenger/MessagesController.java
