+++ b/TMessagesProj/src/main/java/org/telegram/messenger/MessagesController.java
@@ -10505,6 +10505,7 @@ public class MessagesController extends BaseController implements NotificationCe
                 noDialog = true;
             } else if (response instanceof TLRPC.TL_help_promoData) {
                 TLRPC.TL_help_promoData res = (TLRPC.TL_help_promoData) response;
+                desu.inugram.helpers.SuggestionFilter.filterPromoData(res);
 
                 long did;
                 if (res.peer == null) {
