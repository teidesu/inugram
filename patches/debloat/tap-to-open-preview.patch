From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: alina sireneva <alina@tei.su>
Date: Fri, 24 Apr 2026 13:35:21 +0300
Subject: [PATCH] prevent tapping the chat preview from expanding it to avoid
 accidentally opening it

---
 .../src/main/java/org/telegram/ui/DialogsActivity.java          | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/TMessagesProj/src/main/java/org/telegram/ui/DialogsActivity.java b/TMessagesProj/src/main/java/org/telegram/ui/DialogsActivity.java
index 0000000..0000000 100644
--- a/TMessagesProj/src/main/java/org/telegram/ui/DialogsActivity.java
+++ b/TMessagesProj/src/main/java/org/telegram/ui/DialogsActivity.java
@@ -8679,7 +8679,7 @@ public class DialogsActivity extends BaseFragment implements NotificationCenter.
             } else {
                 presentFragmentAsPreviewWithMenu(chatActivity[0] = new ChatActivity(args), previewMenu[0]);
                 if (chatActivity[0] != null) {
-                    chatActivity[0].allowExpandPreviewByClick = true;
+                    chatActivity[0].allowExpandPreviewByClick = !desu.inugram.InuConfig.DISABLE_CHAT_PREVIEW_EXPAND.getValue();
                     try {
                         chatActivity[0].getAvatarContainer().getAvatarImageView().performAccessibilityAction(AccessibilityNodeInfo.ACTION_ACCESSIBILITY_FOCUS, null);
                     } catch (Exception ignore) {
-- 
